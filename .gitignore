# ── Python ────────────────────────────────────────────────────
__pycache__/
*.pyc
*.egg-info/
dist/
build/

# ── OS ────────────────────────────────────────────────────────
.DS_Store
.ipynb_checkpoints/

# ── Data (manually downloaded, too large for git) ────────────
data/pdbbind/

# ── External: ignore large binaries, track source code ───────
external/targetdiff/data/
external/targetdiff/pretrained_models/*.pt
external/targetdiff/pretrained_models/*.pkl
external/targetdiff/**/__pycache__/
external/targetdiff/**/*.pyc

# ── Results: track JSON/txt/figures (small), ignore large binaries ──
results/**/*.npz
results/**/*.npy
results/**/*.pt
results/**/*.sdf
