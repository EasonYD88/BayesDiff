# ── Data (manually downloaded, too large for git) ────────────
data/pdbbind/
data/generated/
data/embeddings/*.npz

# ── External: ignore large binaries, track our own patches ───
external/targetdiff/data/
external/targetdiff/pretrained_models/*.pt
external/targetdiff/pretrained_models/*.pkl
external/targetdiff/**/__pycache__/
external/targetdiff/**/*.pyc
# Keep: external/targetdiff/torch_scatter.py (our shim)
# Keep: external/targetdiff/ source code (if not using submodule)

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.pyc
*.egg-info/
dist/
build/

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/

# ── OS ────────────────────────────────────────────────────────
.DS_Store

# ── Results: track JSON/txt/log/figures (small), ignore large binaries ──
results/**/*.npz
results/**/*.pt
results/**/*.sdf
# Everything else in results/ is tracked (JSON, CSV, TXT, PNG)
